# --- Server ---
PORT=3001
NODE_ENV=development

# --- SMTP (Nodemailer) ---
# Пример: Gmail (нужен App Password), Yandex, Mailtrap, Resend SMTP и т.д.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Адрес, с которого отправляются письма (часто = SMTP_USER)
MAIL_FROM="Dev Landing <your_email@gmail.com>"

# Адрес владельца сайта — туда придёт заявка
OWNER_EMAIL=your_email@gmail.com

# --- Resend ---
RESEND_API_KEY=re_xxx

# --- AI (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
